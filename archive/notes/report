\hline
\end{tabular}
\end{table}

\subsection{Angular Orthogonal Loss}

Based on Orthogonal Projection Loss~\cite{ranasinghe2021}, this loss minimises
the squared inner products between L2-normalised features of different classes:
\begin{equation}
\mathcal{L}_{angular} = \frac{1}{|\mathcal{D}|} \sum_{(i,j) \in \mathcal{D}}
(\hat{\mathbf{f}}_i \cdot \hat{\mathbf{f}}_j)^2
\label{eq:angular}
\end{equation}
where $\mathcal{D}$ is the set of all pairs with different class labels.

\subsection{Mudra Cross-Entropy Loss}

Frame-level mudra supervision penalises incorrect hand gesture predictions,
forcing the model to attend to the 42-point hand region:
\begin{equation}
\mathcal{L}_{mudra} = \frac{1}{B \cdot T} \sum_{b,t} \text{CE}(\hat{m}_{bt}, m_{bt})
\label{eq:mudra}
\end{equation}

